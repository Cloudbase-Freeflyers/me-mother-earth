  "html": "<section id=\"mme-laundry-sheets\"\r\n  style=\"margin:0;background:#f3efe8;color:#2b2b2b;font:16px/1.6 system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;\">\r\n  <!-- HERO -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-0\" class=\"mme-scroll-target\">\r\n\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);overflow:hidden;\">\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:22px;align-items:center;padding:22px;\">\r\n          <!-- Left -->\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <span \n              style=\"display:inline-block;font-size:.78rem;letter-spacing:.14em;text-transform:uppercase;color:#A1AB97;background:#eaf5ef;border:1px solid #d3ebde;padding:6px 10px;border-radius:999px;\">\r\n              Laundry Detergent Sheets\r\n            </span>\r\n\r\n            <h1 style=\"font-size:clamp(2rem,5vw,3.1rem);line-height:1.1;margin:.6rem 0;font-weight:900;\">\r\n              Deeper cleaning — without the <span style=\"color:#A1AB97;\">plastic</span> jug\r\n            </h1>\r\n\r\n            <p style=\"color:#5a6b63;font-size:clamp(1rem,1.6vw,1.15rem);margin:0;\">\r\n              <strong>Tear, toss, and wash.</strong><br>\r\n              These detergent sheets are upgraded with <strong>enzymes</strong> to help break down everyday stains and odors at the source — without bulky liquid bottles, spills, or wasted product.\r\n            </p>\r\n\r\n            <div style=\"margin-top:14px;\">\r\n              <span style=\"display:inline-flex;gap:6px;align-items:center;background:#eaf5ef;border:1px solid #cfe8db;color:#285241;border-radius:999px;padding:6px 10px;font-size:.82rem;\">\r\n                Enzyme-powered • Plastic-free • Works in HE + standard\r\n              </span>\r\n            </div>\r\n\r\n            <!-- CTA (only product page) -->\r\n            <div style=\"margin-top:16px;display:flex;flex-wrap:wrap;gap:12px;align-items:center;\">\r\n              <a href=\"https://memotherearthbrand.com/products/laundry-detergent-sheets\" rel=\"noopener\" style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                       background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                       box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\" data-gtm-cta=\"shopify\">\r\n                Shop Laundry Sheets\r\n              </a>\r\n            </div>\r\n\r\n            <p style=\"margin-top:8px;color:#5a6b63;\">Always mindfully packaged without plastic</p>\r\n\r\n            <!-- QUICK VALUE HIGHLIGHTS -->\r\n            <div style=\"margin-top:16px;\">\r\n              <p style=\"font-weight:900;margin:0 0 10px;color:#2b2b2b;\">Key Benefits</p>\r\n              <div style=\"display:flex;flex-wrap:wrap;gap:10px;\">\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                  With enzymes for stain support\r\n                </span>\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                  Fresh Ocean Breeze scent\r\n                </span>\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                  Compact, easy to store\r\n                </span>\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                  No plastic bottle\r\n                </span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <!-- Right -->\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <div style=\"border-radius:16px;overflow:hidden;border:1px solid #d7c9b8;background:#fff;\">\r\n              <img \n                src=\"https://memotherearthbrand.com/cdn/shop/files/All_Laundry_Sheets.jpg?v=1779143443\"\r\n                alt=\"Laundry detergent sheets\"\r\n                loading=\"lazy\"\r\n                style=\"width:100%;height:auto;display:block;\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- WHY SWITCH -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-1\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;\">\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:22px;align-items:center;\">\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <p style=\"font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">Why switch</p>\r\n            <h2 style=\"margin:.2rem 0 0;\">Laundry detergent — without the bottle</h2>\r\n\r\n            <p style=\"color:#5a6b63;margin-top:10px;\">\r\n              Traditional liquid detergents can mean bulky plastic jugs, sticky spills, and shipping mostly water.\r\n            </p>\r\n            <p style=\"color:#5a6b63;margin-top:10px;\">\r\n              Detergent sheets are lightweight, pre-measured, and designed to dissolve cleanly — with enzymes to support tougher everyday stains.\r\n            </p>\r\n\r\n            <p style=\"font-weight:900;margin:12px 0 6px;\">Why people choose sheets instead:</p>\r\n            <ul style=\"list-style:none;padding:0;margin:10px 0 0;\">\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                No plastic jug\r\n              </li>\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                Pre-measured portions — no spills or overuse\r\n              </li>\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                Works in HE + standard machines\r\n              </li>\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                Lightweight &amp; compact for storage and travel\r\n              </li>\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                Enzymes to support stain and odor removal\r\n              </li>\r\n            </ul>\r\n\r\n            <div style=\"margin-top:16px;\">\r\n              <a href=\"https://memotherearthbrand.com/products/laundry-detergent-sheets\" rel=\"noopener\" style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                       background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                       box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\" data-gtm-cta=\"shopify\">\r\n                Shop Laundry Sheets\r\n              </a>\r\n            </div>\r\n          </div>\r\n\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <div style=\"background:#f7f3ed;border:1px solid #e3d6c7;border-radius:16px;padding:22px;\">\r\n              <h3 style=\"margin:0 0 10px;\">Concentrated Value</h3>\r\n              <div style=\"display:flex;justify-content:center;align-items:center;gap:20px;\">\r\n                <div style=\"flex:0 1 auto;text-align:center;\">\r\n                  <div style=\"font-size:2.5rem;font-weight:900;color:#A1AB97;\">30</div>\r\n                  <div style=\"font-size:12px;text-transform:uppercase;font-weight:700;\">Sheets</div>\r\n                </div>\r\n                <div style=\"width:1px;height:50px;background:#d7c9b8;\"></div>\r\n                <div style=\"flex:0 1 auto;text-align:center;\">\r\n                  <div style=\"font-size:2.5rem;font-weight:900;color:#A1AB97;\">60</div>\r\n                  <div style=\"font-size:12px;text-transform:uppercase;font-weight:700;\">Loads</div>\r\n                </div>\r\n              </div>\r\n              <p style=\"color:#5a6b63;margin:10px 0 0;font-size:14px;text-align:center;\">\r\n                <em>*1 sheet washes 2 small loads or 1 large load.</em>\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- HOW IT WORKS -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-2\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">How it works</p>\r\n      <h2 style=\"text-align:center;margin-top:6px;\">3 quick steps to a fresh load</h2>\r\n\r\n      <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:12px;\">\r\n        <div style=\"flex:1 1 260px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;position:relative;\">\r\n          <span style=\"position:absolute;top:14px;right:14px;background:#eaf5ef;color:#245b44;border:1px solid #cfe8db;border-radius:999px;font-weight:900;font-size:.85rem;padding:3px 8px;\">1</span>\r\n          <h3 style=\"margin-top:0;\">Tear to dose</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">\r\n            Perforated for ease. Use <strong>½ sheet</strong> for small loads, <strong>1 sheet</strong> for medium, and <strong>2 sheets</strong> for large loads.\r\n          </p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 260px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;position:relative;\">\r\n          <span style=\"position:absolute;top:14px;right:14px;background:#eaf5ef;color:#245b44;border:1px solid #cfe8db;border-radius:999px;font-weight:900;font-size:.85rem;padding:3px 8px;\">2</span>\r\n          <h3 style=\"margin-top:0;\">Toss in</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">\r\n            Top-loaders: place sheet on top of laundry. Front-loaders: tear up and place in the detergent drawer.\r\n          </p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 260px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;position:relative;\">\r\n          <span style=\"position:absolute;top:14px;right:14px;background:#eaf5ef;color:#245b44;border:1px solid #cfe8db;border-radius:999px;font-weight:900;font-size:.85rem;padding:3px 8px;\">3</span>\r\n          <h3 style=\"margin-top:0;\">Wash</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">\r\n            Run your cycle. The <strong>enzymes</strong> help break down stains while the sheet dissolves cleanly in hot or cold water.\r\n          </p>\r\n        </div>\r\n      </div>\r\n\r\n      <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n        <a href=\"https://memotherearthbrand.com/products/laundry-detergent-sheets\" rel=\"noopener\" style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                 background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                 box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\" data-gtm-cta=\"shopify\">\r\n          Shop Laundry Sheets\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- WHERE IT SHINES -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-3\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">Where it shines</p>\r\n      <h2 style=\"text-align:center;margin-top:6px;\">Made for real life laundry days</h2>\r\n\r\n      <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;\">\r\n        <article style=\"flex:1 1 300px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;overflow:hidden;\">\r\n          <div style=\"background:#f7f3ed;border-bottom:1px solid #e3d6c7;padding:14px;\">\r\n            <p style=\"margin:0;font-weight:900;color:#245b44;\">Everyday laundry</p>\r\n            <p style=\"margin:6px 0 0;color:#5a6b63;\">Pre-measured sheets make routine washing simple — no drips, no measuring cups.</p>\r\n          </div>\r\n        </article>\r\n\r\n        <article style=\"flex:1 1 300px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;overflow:hidden;\">\r\n          <div style=\"background:#f7f3ed;border-bottom:1px solid #e3d6c7;padding:14px;\">\r\n            <p style=\"margin:0;font-weight:900;color:#245b44;\">Space-saving storage</p>\r\n            <p style=\"margin:6px 0 0;color:#5a6b63;\">Slim, lightweight format fits neatly in cabinets, drawers, or travel bags.</p>\r\n          </div>\r\n        </article>\r\n\r\n        <article style=\"flex:1 1 300px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;overflow:hidden;\">\r\n          <div style=\"background:#f7f3ed;border-bottom:1px solid #e3d6c7;padding:14px;\">\r\n            <p style=\"margin:0;font-weight:900;color:#245b44;\">Enzyme boost</p>\r\n            <p style=\"margin:6px 0 0;color:#5a6b63;\">Enzymes help target common stain types and odor sources during your wash.</p>\r\n          </div>\r\n        </article>\r\n      </div>\r\n\r\n      <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n        <a href=\"https://memotherearthbrand.com/products/laundry-detergent-sheets\" rel=\"noopener\" style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                 background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                 box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\" data-gtm-cta=\"shopify\">\r\n          Shop Laundry Sheets\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- FEATURES & BENEFITS -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-4\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">Features &amp; benefits</p>\r\n      <h2 style=\"text-align:center;margin-top:6px;\">Simple, effective, and intentionally designed</h2>\r\n\r\n      <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;\">\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Enzyme-powered clean</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Enzymes help break down common stain types and odor sources for deeper cleaning support.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Pre-measured sheets</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">No measuring cups. Tear to dose based on load size for consistent use.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Works in HE + standard</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Low-sudsing and compatible with most washing machines.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Lightweight shipping</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Ships compactly versus heavy liquid detergents that are mostly water.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Mess-free laundry</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">No drips, no sticky residue, no detergent spills.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Mindfully packaged</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Always mindfully packaged without plastic.</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n        <a href=\"https://memotherearthbrand.com/products/laundry-detergent-sheets\" rel=\"noopener\" style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                 background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                 box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\" data-gtm-cta=\"shopify\">\r\n          Shop Laundry Sheets\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- CUSTOMER REVIEWS -->\r\n  <div style=\"padding:22px 0;\" aria-label=\"Customer reviews\" id=\"mme-sec-5\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;\">\r\n        <p style=\"font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">What customers say</p>\r\n        <h2 style=\"margin:.2rem 0 0;\">Cleaner loads, less waste</h2>\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:12px;\">\r\n          <div style=\"flex:1 1 300px;min-width:260px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n            <h3 style=\"margin:0 0 8px;\">No more heavy jugs</h3>\r\n            <div style=\"letter-spacing:2px;color:#f1b400;font-size:1.05rem;\">★★★★★</div>\r\n            <p style=\"color:#5a6b63;margin:8px 0;\">\"The sheets are so easy—tear, toss, done. My clothes come out clean and fresh, and I love that there's no plastic bottle to deal with. Game changer for small spaces.\"</p>\r\n            <p style=\"margin:8px 0 0;\"><strong>— Amanda Chen</strong></p>\r\n          </div>\r\n          <div style=\"flex:1 1 300px;min-width:260px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n            <h3 style=\"margin:0 0 8px;\">Stains come out</h3>\r\n            <div style=\"letter-spacing:2px;color:#f1b400;font-size:1.05rem;\">★★★★★</div>\r\n            <p style=\"color:#5a6b63;margin:8px 0;\">\"Switched from liquid and won't go back. The enzyme formula really helps with everyday stains and odors. Plus the Ocean Breeze scent is fresh without being overpowering.\"</p>\r\n            <p style=\"margin:8px 0 0;\"><strong>— Derek Moore</strong></p>\r\n          </div>\r\n          <div style=\"flex:1 1 300px;min-width:260px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n            <h3 style=\"margin:0 0 8px;\">Perfect for travel</h3>\r\n            <div style=\"letter-spacing:2px;color:#f1b400;font-size:1.05rem;\">★★★★★</div>\r\n            <p style=\"color:#5a6b63;margin:8px 0;\">\"Compact, mess-free, and they work in my HE machine. No spills, no measuring—just one sheet per load. My laundry cabinet has never been tidier.\"</p>\r\n            <p style=\"margin:8px 0 0;\"><strong>— Yuki Tanaka</strong></p>\r\n          </div>\r\n        </div>\r\n\r\n        <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n          <a href=\"https://memotherearthbrand.com/products/laundry-detergent-sheets\" rel=\"noopener\" style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                   background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                   box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\" data-gtm-cta=\"shopify\">\r\n            Shop Laundry Sheets\r\n          </a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- INGREDIENT TRANSPARENCY -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-6\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;\">\r\n        <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">Technical transparency</p>\r\n        <h2 style=\"text-align:center;margin-top:6px;\">High-performance ingredients, simplified</h2>\r\n        <p style=\"color:#5a6b63;margin:10px auto 0;max-width:860px;text-align:center;\">\r\n          We prioritize <strong>plant-based surfactants</strong> and mineral ingredients for a high-performance clean.\r\n        </p>\r\n\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;\">\r\n          <div style=\"flex:1 1 360px;min-width:260px;background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;padding:16px;\">\r\n            <p style=\"margin:0;font-weight:900;\">Enzymes</p>\r\n            <p style=\"margin:6px 0 0;color:#5a6b63;\">Help target protein and starch stains and support odor removal.</p>\r\n          </div>\r\n\r\n          <div style=\"flex:1 1 360px;min-width:260px;background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;padding:16px;\">\r\n            <p style=\"margin:0;font-weight:900;\">Plant-based surfactants</p>\r\n            <p style=\"margin:6px 0 0;color:#5a6b63;\">Help lift dirt and soils from fabric fibers.</p>\r\n          </div>\r\n\r\n          <div style=\"flex:1 1 360px;min-width:260px;background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;padding:16px;\">\r\n            <p style=\"margin:0;font-weight:900;\">Saponins</p>\r\n            <p style=\"margin:6px 0 0;color:#5a6b63;\">Plant-derived cleaning agents that support washing performance.</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- HOW TO DOSE -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-7\" class=\"mme
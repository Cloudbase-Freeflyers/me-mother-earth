  "html": "<section id=\"mme-toothpaste-tablets\"\r\n  style=\"margin:0;background:#f3efe8;color:#2b2b2b;font:16px/1.6 system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;\">\r\n  <!-- HERO -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-0\" class=\"mme-scroll-target\">\r\n\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);overflow:hidden;\">\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:22px;align-items:center;padding:22px;\">\r\n          <!-- Left -->\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <span \n              style=\"display:inline-block;font-size:.78rem;letter-spacing:.14em;text-transform:uppercase;color:#A1AB97;background:#eaf5ef;border:1px solid #d3ebde;padding:6px 10px;border-radius:999px;\">\r\n              Zero Waste Toothpaste Tablets\r\n            </span>\r\n\r\n            <h1 style=\"font-size:clamp(2rem,5vw,3.1rem);line-height:1.1;margin:.6rem 0;font-weight:900;\">\r\n              Fresh foam, <span style=\"color:#A1AB97;\">zero tube</span> — in a refillable jar\r\n            </h1>\r\n\r\n            <p style=\"color:#5a6b63;font-size:clamp(1rem,1.6vw,1.15rem);margin:0;\">\r\n              <strong>Chew, brush, breathe out.</strong><br>\r\n              Foamy, minty, plastic-free toothpaste tablets in a refillable amber glass jar. Same clean you love — no tube, no waste. Need more? Get our 3-month refill pouch and pour into your jar.\r\n            </p>\r\n\r\n            <div style=\"margin-top:14px;\">\r\n              <span style=\"display:inline-flex;gap:6px;align-items:center;background:#eaf5ef;border:1px solid #cfe8db;color:#285241;border-radius:999px;padding:6px 10px;font-size:.82rem;\">\r\n                65 tablets per jar · Refillable glass · Peppermint or Strawberry\r\n              </span>\r\n            </div>\r\n\r\n            <!-- CTA: Main product + Refill option -->\r\n            <div style=\"margin-top:16px;display:flex;flex-wrap:wrap;gap:12px;align-items:center;\">\r\n              <a href=\"https://memotherearthbrand.com/products/zero-waste-toothpaste-tablets\"\r\n                rel=\"noopener\"\r\n                style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                       background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                       box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n                Shop Toothpaste Tablets\r\n              </a>\r\n              <a href=\"https://memotherearthbrand.com/products/zero-waste-toothpaste-tablets-3-month-refills\"\r\n                rel=\"noopener\"\r\n                style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                       background:transparent;color:#1e6e4b;font-weight:800;border:2px solid #1e6e4b;\r\n                       text-decoration:none;white-space:nowrap;\">\r\n                Get 3-Month Refill\r\n              </a>\r\n            </div>\r\n\r\n            <p style=\"margin-top:8px;color:#5a6b63;\">Always mindfully packaged without plastic</p>\r\n\r\n            <!-- QUICK VALUE HIGHLIGHTS -->\r\n            <div style=\"margin-top:16px;\">\r\n              <p style=\"font-weight:900;margin:0 0 10px;color:#2b2b2b;\">Key Benefits</p>\r\n              <div style=\"display:flex;flex-wrap:wrap;gap:10px;\">\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                  65 tablets per jar\r\n                </span>\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-
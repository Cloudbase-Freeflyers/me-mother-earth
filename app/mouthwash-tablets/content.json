color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                Plant-powered ingredients\r\n              </span>\r\n              <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                Reusable amber glass jar\r\n              </span>\r\n              <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                100% plastic-free\r\n              </span>\r\n              <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                Vegan &amp; travel-friendly\r\n              </span>\r\n            </div>\r\n\r\n            <div style=\"margin-top:14px;\">\r\n              <span style=\"display:inline-flex;gap:6px;align-items:center;background:#eaf5ef;border:1px solid #cfe8db;color:#285241;border-radius:999px;padding:6px 10px;font-size:.82rem;\">\r\n                No harsh chemicals • No burning sensation • Lightweight\r\n              </span>\r\n            </div>\r\n\r\n            <!-- CTA (only product page) -->\r\n            <div style=\"margin-top:16px;display:flex;flex-wrap:wrap;gap:12px;align-items:center;\">\r\n              <a href=\"https://memotherearthbrand.com/products/zero-waste-mouthwash-tablets\"\r\n                rel=\"noopener\"\r\n                style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                       background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                       box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n                Shop Mouthwash Tablets\r\n              </a>\r\n            </div>\r\n\r\n            <p style=\"margin-top:8px;color:#5a6b63;\">Always mindfully packaged without plastic</p>\r\n          </div>\r\n\r\n          <!-- Right -->\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <div style=\"border-radius:16px;overflow:hidden;border:1px solid #d7c9b8;background:#fff;\">\r\n              <img \n                src=\"https://memotherearthbrand.com/cdn/shop/files/zero_waste_mouthwash_tablets_1512x.jpg?v=1767239151\"\r\n                alt=\"Zero waste mouthwash tablets in reusable amber glass jar\"\r\n                loading=\"lazy\"\r\n                style=\"width:100%;height:auto;display:block;\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- PROBLEM / PROMISE -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-1\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;\">\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:22px;align-items:center;\">\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <p style=\"font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">Why switch</p>\r\n            <h2 style=\"margin:.2rem 0 0;\">Bulky plastic bottles are wasteful and hard to travel with.</h2>\r\n            <p style=\"color:#5a6b63;margin-top:10px;\">\r\n              Mouthwash tablets skip the plastic bottle entirely. They're lightweight, simple to store, and easy to use—plus <strong>plant-powered ingredients</strong> support a fresh-feeling mouth without harsh chemicals or burning sensation.\r\n            </p>\r\n\r\n            <ul style=\"list-style:none;padding:0;margin:10px 0 0;\">\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                Alcohol-free with plant-powered ingredients\r\n              </li>\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                No spills, no bulky bottles\r\n              </li>\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                Cool peppermint finish without burning\r\n              </li>\r\n            </ul>\r\n\r\n            <div style=\"margin-top:16px;\">\r\n              <a href=\"https://memotherearthbrand.com/products/zero-waste-mouthwash-tablets\"\r\n                rel=\"noopener\"\r\n                style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                       background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                       box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n                Shop Mouthwash Tablets\r\n              </a>\r\n            </div>\r\n          </div>\r\n\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <div style=\"border-radius:16px;overflow:hidden;border:1px solid #d7c9b8;background:#fff;\">\r\n              <img \n                src=\"https://memotherearthbrand.com/cdn/shop/files/4B5A5370_540x.jpg?v=1767239151\"\r\n                alt=\"Using mouthwash tablets for fresh breath\"\r\n                loading=\"lazy\"\r\n                style=\"width:100%;height:auto;display:block;\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- HOW IT WORKS -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-2\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">How it works</p>\r\n      <h2 style=\"text-align:center;margin-top:6px;\">3 quick steps to fresh breath</h2>\r\n\r\n      <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:12px;\">\r\n        <div style=\"flex:1 1 260px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;position:relative;\">\r\n          <span style=\"position:absolute;top:14px;right:14px;background:#eaf5ef;color:#245b44;border:1px solid #cfe8db;border-radius:999px;font-weight:900;font-size:.85rem;padding:3px 8px;\">1</span>\r\n          <h3 style=\"margin-top:0;\">Chew</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">\r\n            Chew <strong>one tablet</strong> until fully dissolved. The tablet will start to break down and release its refreshing ingredients.\r\n          </p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 260px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;position:relative;\">\r\n          <span style=\"position:absolute;top:14px;right:14px;background:#eaf5ef;color:#245b44;border:1px solid #cfe8db;border-radius:999px;font-weight:900;font-size:.85rem;padding:3px 8px;\">2</span>\r\n          <h3 style=\"margin-top:0;\">Swish</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">\r\n            Take a <strong>sip of water</strong> and swish around your mouth for 30-60 seconds to distribute the fresh, clean rinse.\r\n          </p>\r\n        </div>\r\n\r\n     
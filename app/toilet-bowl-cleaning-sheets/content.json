padding:16px;\">\r\n            <h3 style=\"margin:0 0 6px;\">Space-saving storage</h3>\r\n            <p style=\"color:#5a6b63;margin:0;\">Slim kraft packaging fits neatly in cabinets, drawers, or small bathrooms.</p>\r\n          </div>\r\n        </article>\r\n\r\n        <article style=\"flex:1 1 300px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;overflow:hidden;\">\r\n          <img src=\"https://memotherearthbrand.com/cdn/shop/files/4B5A5094_2048x.jpg?v=1767240630\"\r\n               alt=\"Toilet cleaning sheets in plastic-free packaging\" loading=\"lazy\" style=\"width:100%;height:auto;display:block;\">\r\n          <div style=\"padding:16px;\">\r\n            <h3 style=\"margin:0 0 6px;\">Streamlined formulas</h3>\r\n            <p style=\"color:#5a6b63;margin:0;\">Formulated to clean effectively without harsh dyes commonly found in liquid toilet cleaners.</p>\r\n          </div>\r\n        </article>\r\n      </div>\r\n\r\n      <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n        <a href=\"https://memotherearthbrand.com/products/toilet-bowl-cleaning-sheets-citrus\"\r\n          rel=\"noopener\"\r\n          style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                 background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                 box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n          Shop Toilet Cleaning Sheets\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- FEATURES & BENEFITS -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-4\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">Features &amp; benefits</p>\r\n      <h2 style=\"text-align:center;margin-top:6px;\">Simple, effective, and intentionally designed</h2>\r\n\r\n      <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;\">\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Plant-derived surfactants</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Uses surfactants derived from coconut and sugar sources to help break down buildup and residue.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Pre-measured portions</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Each sheet is perforated into three portions. <strong>12 sheets = up to 36 cleans.</strong></p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Plastic-free swap</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Eliminates the need for bulky plastic bottles.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Lightweight shipping</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Sheets weigh significantly less than traditional liquid cleaners filled mostly with water, helping reduce shipping bulk and unnecessary material use.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Mess-free cleaning</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">No spills, no sticky residue, no measuring.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Mindfully packaged</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Packaged in recyclable or compostable kraft paper — never plastic.</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n        <a href=\"https://memotherearthbrand.com/products/toilet-bowl-cleaning-sheets-citrus\"\r\n          rel=\"noopener\"\r\n          style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                 background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                 box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n          Shop Toilet Cleaning Sheets\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- CUSTOMER REVIEWS -->\r\n  <div style=\"padding:22px 0;\" aria-label=\"Customer reviews\" id=\"mme-sec-5\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;\">\r\n        <p style=\"font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">What customers say</p>\r\n        <h2 style=\"margin:.2rem 0 0;\">Clean bowl, no plastic bottle</h2>\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:12px;\">\r\n          <div style=\"flex:1 1 300px;min-width:260px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n            <h3 style=\"margin:0 0 8px;\">So much easier</h3>\r\n            <div style=\"letter-spacing:2px;color:#f1b400;font-size:1.05rem;\">★★★★★</div>\r\n            <p style=\"color:#5a6b63;margin:8px 0;\">\"Tear one portion, drop it in, scrub, and flus
  "html": "<section id=\"mme-tongue-scraper\"\r\n  style=\"margin:0;background:#f3efe8;color:#2b2b2b;font:16px/1.6 system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;\">\r\n  <!-- HERO -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-0\" class=\"mme-scroll-target\">\r\n\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);overflow:hidden;\">\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:22px;align-items:center;padding:22px;\">\r\n          <!-- Left -->\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <span \n              style=\"display:inline-block;font-size:.78rem;letter-spacing:.14em;text-transform:uppercase;color:#A1AB97;background:#eaf5ef;border:1px solid #d3ebde;padding:6px 10px;border-radius:999px;\">\r\n              Stainless Steel Tongue Scraper\r\n            </span>\r\n\r\n            <h1 style=\"font-size:clamp(2rem,5vw,3.1rem);line-height:1.1;margin:.6rem 0;font-weight:900;\">\r\n              A cleaner mouth in <span style=\"color:#A1AB97;\">seconds</span> — just a few gentle strokes each morning\r\n            </h1>\r\n\r\n            <p style=\"color:#5a6b63;font-size:clamp(1rem,1.6vw,1.15rem);margin:0;\">\r\n              <strong>Scrape, rinse, done.</strong><br>\r\n              This surgical-grade stainless steel tongue scraper removes odor-causing bacteria and buildup more effectively than brushing alone — built to last a lifetime with zero plastic waste.\r\n            </p>\r\n\r\n            <div style=\"margin-top:14px;\">\r\n              <span style=\"display:inline-flex;gap:6px;align-items:center;background:#eaf5ef;border:1px solid #cfe8db;color:#285241;border-radius:999px;padding:6px 10px;font-size:.82rem;\">\r\n                Surgical-grade steel • Plastic-free • Lasts a lifetime\r\n              </span>\r\n            </div>\r\n\r\n            <!-- CTA (only product page) -->\r\n            <div style=\"margin-top:16px;display:flex;flex-wrap:wrap;gap:12px;align-items:center;\">\r\n              <a href=\"https://memotherearthbrand.com/products/stainless-steel-tongue-scraper\"\r\n                rel=\"noopener\"\r\n                style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                       background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                       box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n                Shop Tongue Scraper\r\n              </a>\r\n            </div>\r\n\r\n            <p style=\"margin-top:8px;color:#5a6b63;\">Always mindfully packaged without plastic</p>\r\n\r\n            <!-- QUICK VALUE HIGHLIGHTS -->\r\n            <div style=\"margin-top:16px;\">\r\n              <p style=\"font-weight:900;margin:0 0 10px;color:#2b2b2b;\">Key Benefits</p>\r\n              <div style=\"display:flex;flex-wrap:wrap;gap:10px;\">\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                  Surgical-grade steel\r\n                </span>\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                  Removes odor-causing bacteria\r\n                </span>\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                  Lifetime durability\r\n                </span>\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                  100% plastic-free\r\n                </span>\r\n                <span style=\"display:inline-flex;align-items:center;background:#fff;border:1px solid #d7c9b8;color:#365846;padding:8px 16px;border-radius:999px;font-size:12px;\">\r\n                  Easy to clean\r\n                </span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <!-- Right -->\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <div style=\"border-radius:16px;overflow:hidden;border:1px solid #d7c9b8;background:#fff;\">\r\n              <img \n                src=\"https://cdn.shopify.com/s/files/1/0159/6647/0198/files/ToungueScrapper.jpg?v=1762458224\"\r\n                alt=\"Stainless steel tongue scraper\"\r\n                loading=\"lazy\"\r\n                style=\"width:100%;height:auto;display:block;\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- WHY SWITCH -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-1\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;\">\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:22px;align-items:center;\">\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <p style=\"font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">Why switch</p>\r\n            <h2 style=\"margin:.2rem 0 0;\">A better approach to tongue cleaning</h2>\r\n\r\n            <p style=\"color:#5a6b63;margin-top:10px;\">\r\n              Toothbrushes are designed for teeth — they push bacteria around the tongue surface rather than removing it. Most plastic tongue scrapers flex, wear out, and end up in the trash after a few months.\r\n            </p>\r\n            <p style=\"color:#5a6b63;margin-top:10px;\">\r\n              This stainless steel scraper uses a firm, smooth edge to lift and remove the coating where bad breath originates — and it's built to last indefinitely without replacement.\r\n            </p>\r\n\r\n            <p style=\"font-weight:900;margin:12px 0 6px;\">Why people choose stainless steel:</p>\r\n            <ul style=\"list-style:none;padding:0;margin:10px 0 0;\">\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                More effective at removing tongue coating than toothbrush bristles\r\n              </li>\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                Surgical-grade steel — won't flex, crack, or degrade\r\n              </li>\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                Buy once, use for life — no repeated plastic purchases\r\n              </li>\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                Easy to rinse and keep hygienic\r\n              </li>\r\n              <li style=\"display:flex;gap:10px;margin:8px 0;\">\r\n                <span style=\"width:24px;height:24px;border-radius:999px;background:#eaf5ef;border:1px solid #cfe8db;color:#A1AB97;font-weight:900;display:inline-grid;place-items:center;flex:0 0 24px;\">✓</span>\r\n                No plastic — ever\r\n              </li>\r\n            </ul>\r\n\r\n            <div style=\"margin-top:16px;\">\r\n              <a href=\"https://memotherearthbrand.com/products/stainless-steel-tongue-scraper\"\r\n                rel=\"noopener\"\r\n                style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                       background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                       box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n                Shop Tongue Scraper\r\n              </a>\r\n            </div>\r\n          </div>\r\n\r\n          <div style=\"flex:1 1 420px;min-width:280px;\">\r\n            <div style=\"border-radius:16px;overflow:hidden;border:1px solid #d7c9b8;background:#fff;\">\r\n              <img \n                src=\"https://cdn.shopify.com/s/files/1/0159/6647/0198/files/tongue_scraper_in_use.jpg?v=1767241771\"\r\n                alt=\"Stainless steel tongue scraper in use\"\r\n                loading=\"lazy\"\r\n                style=\"width:100%;height:auto;display:block;\">\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- HOW IT WORKS -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-2\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">How it works</p>\r\n      <h2 style=\"text-align:center;margin-top:6px;\">3 quick steps to a cleaner tongue</h2>\r\n\r\n      <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:12px;\">\r\n        <div style=\"flex:1 1 260px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;position:relative;\">\r\n          <span style=\"position:absolute;top:14px;right:14px;background:#eaf5ef;color:#245b44;border:1px solid #cfe8db;border-radius:999px;font-weight:900;font-size:.85rem;padding:3px 8px;\">1</span>\r\n          <h3 style=\"margin-top:0;\">Place</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">\r\n            Hold both handles and place the curved edge at the back of your tongue.\r\n          </p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 260px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;position:relative;\">\r\n          <span style=\"position:absolute;top:14px;right:14px;background:#eaf5ef;color:#245b44;border:1px solid #cfe8db;border-radius:999px;font-weight:900;font-size:.85rem;padding:3px 8px;\">2</span>\r\n          <h3 style=\"margin-top:0;\">Scrape</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">\r\n            Gently pull forward in one smooth stroke, removing the coating and bacteria.\r\n          </p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 260px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;position:relative;\">\r\n          <span style=\"position:absolute;top:14px;right:14px;background:#eaf5ef;color:#245b44;border:1px solid #cfe8db;border-radius:999px;font-weight:900;font-size:.85rem;padding:3px 8px;\">3</span>\r\n          <h3 style=\"margin-top:0;\">Rinse</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">\r\n            Rinse the scraper under the tap. Repeat 2–3 times for a fully clean tongue.\r\n          </p>\r\n        </div>\r\n      </div>\r\n\r\n      <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n        <a href=\"https://memotherearthbrand.com/products/stainless-steel-tongue-scraper\"\r\n          rel=\"noopener\"\r\n          style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                 background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                 box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n          Shop Tongue Scraper\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- WHERE IT SHINES -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-3\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">Where it shines</p>\r\n      <h2 style=\"text-align:center;margin-top:6px;\">Designed for daily oral care routines</h2>\r\n\r\n      <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;\">\r\n        <article style=\"flex:1 1 300px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;overflow:hidden;\">\r\n          <img src=\"https://cdn.shopify.com/s/files/1/0159/6647/0198/files/ToungueScrapper2.jpg?v=1767241771\"\r\n               alt=\"Tongue scraper for morning routine\" loading=\"lazy\" style=\"width:100%;height:auto;display:block;\">\r\n          <div style=\"padding:16px;\">\r\n            <h3 style=\"margin:0 0 6px;\">Morning routine</h3>\r\n            <p style=\"color:#5a6b63;margin:0;\">Start the day with a clean tongue — use before brushing for optimal results.</p>\r\n          </div>\r\n        </article>\r\n\r\n        <article style=\"flex:1 1 300px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;overflow:hidden;\">\r\n          <img src=\"https://cdn.shopify.com/s/files/1/0159/6647/0198/files/tongue_scraper_in_use.jpg?v=1767241771\"\r\n               alt=\"Tongue scraper compact for travel\" loading=\"lazy\" style=\"width:100%;height:auto;display:block;\">\r\n          <div style=\"padding:16px;\">\r\n            <h3 style=\"margin:0 0 6px;\">Travel-ready</h3>\r\n            <p style=\"color:#5a6b63;margin:0;\">Slim and compact — fits in any toiletry bag without taking up space.</p>\r\n          </div>\r\n        </article>\r\n\r\n        <article style=\"flex:1 1 300px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;overflow:hidden;\">\r\n          <img src=\"https://cdn.shopify.com/s/files/1/0159/6647/0198/files/ToungueScrapper1.jpg?v=1767241771\"\r\n               alt=\"Stainless steel tongue scraper detail\" loading=\"lazy\" style=\"width:100%;height:auto;display:block;\">\r\n          <div style=\"padding:16px;\">\r\n            <h3 style=\"margin:0 0 6px;\">Built to last</h3>\r\n            <p style=\"color:#5a6b63;margin:0;\">One stainless steel scraper replaces dozens of plastic ones over a lifetime.</p>\r\n          </div>\r\n        </article>\r\n      </div>\r\n\r\n      <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n        <a href=\"https://memotherearthbrand.com/products/stainless-steel-tongue-scraper\"\r\n          rel=\"noopener\"\r\n          style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                 background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                 box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n          Shop Tongue Scraper\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- FEATURES & BENEFITS -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-4\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">Features &amp; benefits</p>\r\n      <h2 style=\"text-align:center;margin-top:6px;\">Simple, effective, and intentionally designed</h2>\r\n\r\n      <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;\">\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Surgical-grade stainless steel</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Food-safe, rust-resistant, and designed for daily use without degrading.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Removes odor-causing bacteria</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Lifts the tongue coating where VSCs (volatile sulfur compounds) accumulate and cause bad breath.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Lifetime durability</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Buy once and keep it — no warping, no cracking, no need to replace.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Ergonomic dual handles</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Wide grip for comfortable, controlled use — easy to hold even when wet.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Easy to clean</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Rinse under the tap after each use. Dishwasher safe for deep cleaning.</p>\r\n        </div>\r\n\r\n        <div style=\"flex:1 1 280px;min-width:240px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n          <h3 style=\"margin-top:0;\">Plastic-free packaging</h3>\r\n          <p style=\"color:#5a6b63;margin:0;\">Arrives in plastic-free kraft packaging — nothing unnecessary.</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n        <a href=\"https://memotherearthbrand.com/products/stainless-steel-tongue-scraper\"\r\n          rel=\"noopener\"\r\n          style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                 background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                 box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n          Shop Tongue Scraper\r\n        </a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- CUSTOMER REVIEWS -->\r\n  <div style=\"padding:22px 0;\" aria-label=\"Customer reviews\" id=\"mme-sec-5\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;\">\r\n        <p style=\"font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">What customers say</p>\r\n        <h2 style=\"margin:.2rem 0 0;\">Clean tongue, fresh breath</h2>\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:12px;\">\r\n          <div style=\"flex:1 1 300px;min-width:260px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n            <h3 style=\"margin:0 0 8px;\">Simple and effective</h3>\r\n            <div style=\"letter-spacing:2px;color:#f1b400;font-size:1.05rem;\">★★★★★</div>\r\n            <p style=\"color:#5a6b63;margin:8px 0;\">\"The stainless steel tongue scraper is easy to use and my breath feels so much fresher. No more plastic—just a solid, durable tool that does the job.\"</p>\r\n            <p style=\"margin:8px 0 0;\"><strong>— Rachel Kim</strong></p>\r\n          </div>\r\n          <div style=\"flex:1 1 300px;min-width:260px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n            <h3 style=\"margin:0 0 8px;\">Best one I've tried</h3>\r\n            <div style=\"letter-spacing:2px;color:#f1b400;font-size:1.05rem;\">★★★★★</div>\r\n            <p style=\"color:#5a6b63;margin:8px 0;\">\"Sturdy, hygienic, and the right shape for my tongue. I use it every morning and it's become part of my routine. Highly recommend.\"</p>\r\n            <p style=\"margin:8px 0 0;\"><strong>— Tom Foster</strong></p>\r\n          </div>\r\n          <div style=\"flex:1 1 300px;min-width:260px;background:#fff;border:1px solid #d7c9b8;border-radius:14px;padding:18px;\">\r\n            <h3 style=\"margin:0 0 8px;\">Noticeable difference</h3>\r\n            <div style=\"letter-spacing:2px;color:#f1b400;font-size:1.05rem;\">★★★★★</div>\r\n            <p style=\"color:#5a6b63;margin:8px 0;\">\"Switched from a plastic scraper to this stainless steel one. It's comfortable, cleans well, and doesn't bend. My mouth feels cleaner every day.\"</p>\r\n            <p style=\"margin:8px 0 0;\"><strong>— Nina Rodriguez</strong></p>\r\n          </div>\r\n        </div>\r\n\r\n        <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n          <a href=\"https://memotherearthbrand.com/products/stainless-steel-tongue-scraper\"\r\n            rel=\"noopener\"\r\n            style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                   background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                   box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n            Shop Tongue Scraper\r\n          </a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- MATERIAL TRANSPARENCY -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-6\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;\">\r\n        <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">Material transparency</p>\r\n        <h2 style=\"text-align:center;margin-top:6px;\">What it's made of</h2>\r\n        <p style=\"color:#5a6b63;margin:10px auto 0;max-width:860px;text-align:center;\">\r\n          We believe in clear, honest product information. Here's exactly what you're getting:\r\n        </p>\r\n\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;\">\r\n          <div style=\"flex:1 1 360px;min-width:260px;background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;padding:16px;\">\r\n            <p style=\"margin:0;font-weight:900;\">304 Stainless Steel</p>\r\n            <p style=\"margin:6px 0 0;color:#5a6b63;\">Food-grade and surgical-grade steel that resists rust and corrosion with everyday use.</p>\r\n          </div>\r\n\r\n          <div style=\"flex:1 1 360px;min-width:260px;background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;padding:16px;\">\r\n            <p style=\"margin:0;font-weight:900;\">Smooth scraping edge</p>\r\n            <p style=\"margin:6px 0 0;color:#5a6b63;\">Precisely formed edge — firm enough to remove buildup, gentle enough for daily use.</p>\r\n          </div>\r\n\r\n          <div style=\"flex:1 1 360px;min-width:260px;background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;padding:16px;\">\r\n            <p style=\"margin:0;font-weight:900;\">No plastic components</p>\r\n            <p style=\"margin:6px 0 0;color:#5a6b63;\">100% metal construction — nothing that wears out, degrades, or needs replacing.</p>\r\n          </div>\r\n\r\n          <div style=\"flex:1 1 360px;min-width:260px;background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;padding:16px;\">\r\n            <p style=\"margin:0;font-weight:900;\">Kraft paper packaging</p>\r\n            <p style=\"margin:6px 0 0;color:#5a6b63;\">Recyclable or compostable kraft packaging with no plastic wrapping or inserts.</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- HOW TO USE -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-7\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;\">\r\n        <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">How to use</p>\r\n        <h2 style=\"text-align:center;margin-top:6px;\">Use daily, before brushing</h2>\r\n        <p style=\"color:#5a6b63;margin:10px auto 0;max-width:860px;text-align:center;\">\r\n          Best used in the morning before brushing your teeth. <strong>2–3 gentle strokes</strong> is all it takes.\r\n        </p>\r\n\r\n        <div style=\"display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;\">\r\n          <div style=\"flex:1 1 260px;min-width:240px;background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;padding:16px;text-align:center;\">\r\n            <p style=\"margin:0;font-weight:900;\">1 — Place at back of tongue</p>\r\n          </div>\r\n          <div style=\"flex:1 1 260px;min-width:240px;background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;padding:16px;text-align:center;\">\r\n            <p style=\"margin:0;font-weight:900;\">2 — Pull forward gently</p>\r\n          </div>\r\n          <div style=\"flex:1 1 260px;min-width:240px;background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;padding:16px;text-align:center;\">\r\n            <p style=\"margin:0;font-weight:900;\">3 — Rinse &amp; repeat</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- FAQ (NO JS; PageFly-safe) -->\r\n  <div style=\"padding:22px 0;\" id=\"mme-sec-8\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;\">\r\n        <p style=\"text-align:center;font-weight:800;color:#A1AB97;letter-spacing:.08em;text-transform:uppercase;margin:0;\">FAQ</p>\r\n        <h2 style=\"text-align:center;margin-top:6px;\">Questions about the Tongue Scraper</h2>\r\n        <p style=\"color:#5a6b63;margin:10px auto 0;max-width:860px;text-align:center;\">\r\n          Quick answers to help you get the best results.\r\n        </p>\r\n\r\n        <div style=\"margin-top:16px;display:flex;flex-direction:column;gap:12px;\">\r\n\r\n          <!-- Item 1 -->\r\n          <details style=\"background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;overflow:hidden;\">\r\n            <summary style=\"cursor:pointer;list-style:none;padding:14px 14px;display:flex;align-items:center;justify-content:space-between;gap:12px;\">\r\n              <span style=\"font-weight:900;\">What is a tongue scraper and why use one?</span>\r\n              <span style=\"width:28px;height:28px;border-radius:999px;background:#fff;border:1px solid #e3d6c7;display:inline-grid;place-items:center;font-weight:900;color:#245b44;\">+</span>\r\n            </summary>\r\n            <div style=\"padding:0 14px 14px;\">\r\n              <p style=\"margin:0;color:#5a6b63;\">\r\n                A tongue scraper removes the bacteria-laden coating that builds up on the tongue surface overnight. This coating is a primary source of bad breath. Scraping is more effective at removing it than brushing alone.\r\n              </p>\r\n            </div>\r\n          </details>\r\n\r\n          <!-- Item 2 -->\r\n          <details style=\"background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;overflow:hidden;\">\r\n            <summary style=\"cursor:pointer;list-style:none;padding:14px 14px;display:flex;align-items:center;justify-content:space-between;gap:12px;\">\r\n              <span style=\"font-weight:900;\">Is stainless steel better than plastic for tongue scrapers?</span>\r\n              <span style=\"width:28px;height:28px;border-radius:999px;background:#fff;border:1px solid #e3d6c7;display:inline-grid;place-items:center;font-weight:900;color:#245b44;\">+</span>\r\n            </summary>\r\n            <div style=\"padding:0 14px 14px;\">\r\n              <p style=\"margin:0;color:#5a6b63;\">\r\n                Yes. Stainless steel is more hygienic (non-porous), more durable (won't flex or crack), and lasts indefinitely. Plastic scrapers degrade over time and need regular replacement.\r\n              </p>\r\n            </div>\r\n          </details>\r\n\r\n          <!-- Item 3 -->\r\n          <details style=\"background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;overflow:hidden;\">\r\n            <summary style=\"cursor:pointer;list-style:none;padding:14px 14px;display:flex;align-items:center;justify-content:space-between;gap:12px;\">\r\n              <span style=\"font-weight:900;\">How often should I use a tongue scraper?</span>\r\n              <span style=\"width:28px;height:28px;border-radius:999px;background:#fff;border:1px solid #e3d6c7;display:inline-grid;place-items:center;font-weight:900;color:#245b44;\">+</span>\r\n            </summary>\r\n            <div style=\"padding:0 14px 14px;\">\r\n              <p style=\"margin:0;color:#5a6b63;\">\r\n                Daily use is recommended — ideally each morning before brushing your teeth. 2–3 gentle strokes from back to front is sufficient.\r\n              </p>\r\n            </div>\r\n          </details>\r\n\r\n          <!-- Item 4 -->\r\n          <details style=\"background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;overflow:hidden;\">\r\n            <summary style=\"cursor:pointer;list-style:none;padding:14px 14px;display:flex;align-items:center;justify-content:space-between;gap:12px;\">\r\n              <span style=\"font-weight:900;\">How do I clean the tongue scraper?</span>\r\n              <span style=\"width:28px;height:28px;border-radius:999px;background:#fff;border:1px solid #e3d6c7;display:inline-grid;place-items:center;font-weight:900;color:#245b44;\">+</span>\r\n            </summary>\r\n            <div style=\"padding:0 14px 14px;\">\r\n              <p style=\"margin:0;color:#5a6b63;\">\r\n                Rinse thoroughly under running water after each use. For a deeper clean, it can go in the dishwasher. The stainless steel won't rust or corrode.\r\n              </p>\r\n            </div>\r\n          </details>\r\n\r\n          <!-- Item 5 -->\r\n          <details style=\"background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;overflow:hidden;\">\r\n            <summary style=\"cursor:pointer;list-style:none;padding:14px 14px;display:flex;align-items:center;justify-content:space-between;gap:12px;\">\r\n              <span style=\"font-weight:900;\">Will it cause a gag reflex?</span>\r\n              <span style=\"width:28px;height:28px;border-radius:999px;background:#fff;border:1px solid #e3d6c7;display:inline-grid;place-items:center;font-weight:900;color:#245b44;\">+</span>\r\n            </summary>\r\n            <div style=\"padding:0 14px 14px;\">\r\n              <p style=\"margin:0;color:#5a6b63;\">\r\n                Start closer to the middle of the tongue and gradually work further back as you get comfortable. Most people adapt quickly within the first few uses.\r\n              </p>\r\n            </div>\r\n          </details>\r\n\r\n          <!-- Item 6 -->\r\n          <details style=\"background:#f7f3ed;border:1px solid #e3d6c7;border-radius:14px;overflow:hidden;\">\r\n            <summary style=\"cursor:pointer;list-style:none;padding:14px 14px;display:flex;align-items:center;justify-content:space-between;gap:12px;\">\r\n              <span style=\"font-weight:900;\">Does it come in plastic-free packaging?</span>\r\n              <span style=\"width:28px;height:28px;border-radius:999px;background:#fff;border:1px solid #e3d6c7;display:inline-grid;place-items:center;font-weight:900;color:#245b44;\">+</span>\r\n            </summary>\r\n            <div style=\"padding:0 14px 14px;\">\r\n              <p style=\"margin:0;color:#5a6b63;\">\r\n                Yes. The tongue scraper ships in recyclable kraft paper packaging with no plastic wrap, no plastic inserts, and no unnecessary materials.\r\n              </p>\r\n            </div>\r\n          </details>\r\n\r\n        </div>\r\n\r\n        <div style=\"margin-top:16px;display:flex;justify-content:center;\">\r\n          <a href=\"https://memotherearthbrand.com/products/stainless-steel-tongue-scraper\"\r\n            rel=\"noopener\"\r\n            style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                   background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                   box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n            Shop Tongue Scraper\r\n          </a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- BRAND STATEMENT -->\r\n  <div style=\"padding:22px 0;\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#eaf5ef;border:1px solid #cfe8db;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.08);padding:22px;text-align:center;\">\r\n        <p style=\"margin:0;font-weight:900;font-size:1.15rem;color:#245b44;\">Always mindfully packaged without plastic.</p>\r\n        <p style=\"margin:8px auto 0;max-width:900px;color:#3e6b58;\">\r\n          Designed to simplify daily routines while reducing unnecessary waste — one swap at a time.\r\n        </p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- FINAL CTA -->\r\n  <div style=\"padding:22px 0 34px;\" id=\"mme-sec-9\" class=\"mme-scroll-target\">\r\n    <div style=\"max-width:1140px;margin:0 auto;padding:0 16px;\">\r\n      <div style=\"background:#fff;border:1px solid #d7c9b8;border-radius:16px;box-shadow:0 10px 28px rgba(22,35,28,.10);padding:22px;text-align:center;\">\r\n        <h2 style=\"margin:6px 0 10px;\">Make the switch to a stainless steel tongue scraper</h2>\r\n\r\n        <div style=\"display:flex;justify-content:center;margin-top:10px;\">\r\n          <a href=\"https://memotherearthbrand.com/products/stainless-steel-tongue-scraper\"\r\n            rel=\"noopener\"\r\n            style=\"display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:999px;\r\n                   background:linear-gradient(180deg,#A1AB97,#1e6e4b);color:#fff;font-weight:800;border:0;\r\n                   box-shadow:0 10px 28px rgba(22,35,28,.10);text-decoration:none;white-space:nowrap;\">\r\n            Shop Tongue Scraper\r\n          </a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>",
